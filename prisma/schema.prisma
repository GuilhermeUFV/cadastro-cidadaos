generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Citizen {
  id        Int      @id @default(autoincrement())
  fullName  String
  cpf       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
